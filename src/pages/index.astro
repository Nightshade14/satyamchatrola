---
import Base from '../layouts/Base.astro';
import GpuScene from '../components/GpuScene.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const RESUME = `${base}/pdf/Satyam_Chandrakant_Chatrola_Resume.pdf`;
const PAPER_PDF = `${base}/pdf/satyam-chatrola-research-paper.pdf`;
const PAPER_URL =
  'https://www.researchgate.net/publication/388835538_Benchmarking_Fine-Tuned_Transformers_LLMs_and_LSTM_Networks_for_Automated_Essay_Scoring';

// The hero "response" — streamed token by token like a model decoding.
// Clicking "resample" re-runs the decode with another line from this pool.
const RESPONSES = [
  'AI Systems Engineer. I build low-latency systems that serve large language models — from inference optimization and serving infrastructure to ML at planet scale.',
  'AI Systems Engineer. I turn trained models into fast, dependable endpoints — quantization, batching, and caching that cut both latency and cost.',
  'AI Systems Engineer. I care about the last mile of ML: serving it at low latency, high throughput, and low cost — reliably, and at scale.',
  'AI Systems Engineer. From autograd to vLLM, I know the whole stack — so I can make inference genuinely fast, not just barely working.',
];
const RESPONSE = RESPONSES[0];

// Count-up figures for the "signal" section — real, from shipped work.
const stats = [
  { value: 7, decimals: 0, prefix: '', suffix: '×', label: 'inference speedup' },
  { value: 0.96, decimals: 2, prefix: '', suffix: '', label: 'F1 · 750+ profiles' },
  { value: 5, decimals: 0, prefix: '', suffix: 'M+', label: 'SKUs searched' },
  { value: 34, decimals: 0, prefix: '+', suffix: '%', label: 'click-through lift' },
];

const focus = [
  {
    k: 'inference',
    title: 'Inference optimization',
    body: 'Cutting latency and cost out of model serving — batching, KV-cache reuse, quantization, and semantic caching to shave every millisecond off time-to-first-token.',
  },
  {
    k: 'serving',
    title: 'Serving infrastructure',
    body: 'Packaging models as reliable, reproducible low-latency endpoints with vLLM, Truss, and Docker — shipped through CI/CD and built to stay up under load.',
  },
  {
    k: 'internals',
    title: 'Systems from first principles',
    body: 'Understanding the stack end to end: autograd, transformer internals, and language models built from scratch — so optimization is grounded, not guessed.',
  },
  {
    k: 'scale',
    title: 'Scale & reliability',
    body: 'Designing planet-scale AI systems with software-engineering rigor and MLOps discipline — efficient, observable, and robust in production.',
  },
];

const highlights = [
  'Delivered up to 7× inference speedups through quantization, and shipped low-latency inference microservices into production.',
  'Architected a real-time facial recognition & authentication system reaching 0.96 F1 across 750+ profiles on live video — new identities enroll with no retraining.',
  'Built hyper-personalized search over 5M+ SKUs and recommenders that lifted conversion 7.2% and click-through 34%.',
];

const creds = [
  'AWS-Certified ML Engineer',
  '1st Runner-Up · Qualcomm × Microsoft Edge AI Hackathon',
  'MS Computer Science · NYU',
];

const projects = [
  {
    name: 'research-mate',
    tag: 'RAG · latency',
    desc: 'Contextual-RAG research assistant on AWS. Compresses embeddings with binary quantization and keeps the vector store in memory to minimize retrieval latency at scale.',
    lang: 'Python',
    star: 2,
    url: 'https://github.com/Nightshade14/research-mate',
  },
  {
    name: 'vllm-demo',
    tag: 'serving',
    desc: 'Reproducible LLM serving with vLLM, packaged in Docker images for consistent, portable high-throughput inference.',
    lang: 'Docker',
    star: 0,
    url: 'https://github.com/Nightshade14/vllm-demo',
  },
  {
    name: 'semantic_cache_and_RAG',
    tag: 'caching',
    desc: 'Semantic cache, vector store, and RAG built on FAISS — cutting repeat-query latency and cost by serving from cache when meaning matches.',
    lang: 'Notebook',
    star: 0,
    url: 'https://github.com/Nightshade14/semantic_cache_and_RAG',
  },
  {
    name: 'truss-demo',
    tag: 'deployment',
    desc: 'Model packaging and deployment with Truss — turning a trained model into a served endpoint with minimal glue.',
    lang: 'Python',
    star: 0,
    url: 'https://github.com/Nightshade14/truss-demo',
  },
  {
    name: 'my_LLM',
    tag: 'from scratch',
    desc: 'A language model built from scratch in PyTorch, iteratively evolved from foundations toward current industry-standard architecture.',
    lang: 'PyTorch',
    star: 0,
    url: 'https://github.com/Nightshade14/my_LLM',
  },
  {
    name: 'my_micrograd',
    tag: 'foundations',
    desc: "Reimplementing Karpathy's micrograd — a tiny autograd engine — to understand backprop from first principles.",
    lang: 'Python',
    star: 0,
    url: 'https://github.com/Nightshade14/my_micrograd',
  },
];

const links = [
  { label: 'GitHub', handle: '@Nightshade14', url: 'https://github.com/Nightshade14' },
  { label: 'LinkedIn', handle: 'in/satyamchatrola', url: 'https://www.linkedin.com/in/satyamchatrola' },
  { label: 'Kaggle', handle: '@satyamchatrola', url: 'https://www.kaggle.com/satyamchatrola' },
  {
    label: 'Google Cloud',
    handle: 'profile ↗',
    url: 'https://cloudskillsboost.google/public_profiles/8f8d70ce-809c-45e2-b6ba-022e3bc4cf9f',
  },
];
---

<Base
  title="Satyam Chatrola — AI Systems Engineer · LLM inference & serving"
  description="Satyam Chatrola is an AI Systems Engineer specializing in LLM inference and serving — low-latency model serving, inference optimization, and ML systems at scale."
>
  <!-- ================= NAV ================= -->
  <header class="nav">
    <div class="shell nav-inner">
      <a class="brand" href="#top" aria-label="Satyam Chatrola — home">
        <span class="brand-dot"></span>satyam<span class="brand-2">.chatrola</span>
      </a>
      <nav class="nav-links" aria-label="Primary">
        <a href="#focus">focus</a>
        <a href="#work">work</a>
        <a href="#research">research</a>
        <a class="btn btn-sm" href={RESUME} target="_blank" rel="noopener">Résumé <span aria-hidden="true">↗</span></a>
      </nav>
    </div>
  </header>

  <div class="spotlight" aria-hidden="true"></div>

  <main id="top">
    <!-- ================= HERO ================= -->
    <section class="hero shell">
      <div class="hero-copy">
        <p class="prompt" data-reveal><span class="prompt-caret">&gt;</span> whoami</p>

        <h1 class="hero-name" data-reveal style="--reveal-delay: 90ms">
          Satyam<br />Chatrola
        </h1>

        <p class="hero-response" data-reveal style="--reveal-delay: 180ms">
          <span id="decode" data-full={RESPONSE} aria-label={RESPONSE}></span><span class="cursor" id="cursor" aria-hidden="true"></span>
        </p>

        <div class="hero-meta" data-reveal style="--reveal-delay: 260ms">
          <div class="telemetry" aria-hidden="true">
            <span class="tel-item"><span id="tokcount">0</span> tokens</span>
            <span class="tel-sep">·</span>
            <span class="tel-item"><span id="tokrate">—</span> tok/s</span>
            <span class="tel-bar"><span class="tel-fill" id="telfill"></span></span>
            <span class="tel-status" id="telstatus">streaming</span>
          </div>
          <button class="regen" id="regen" type="button" aria-label="Regenerate the response">
            <span class="regen-ico" aria-hidden="true">↻</span> resample
          </button>
        </div>

        <div class="hero-cta" data-reveal style="--reveal-delay: 340ms">
          <a class="btn btn-primary" data-magnetic href="#work">View work</a>
          <a class="btn" data-magnetic href={RESUME} target="_blank" rel="noopener">Download résumé <span aria-hidden="true">↗</span></a>
        </div>
      </div>

      <div class="hero-visual">
        <GpuScene />
      </div>
    </section>

    <!-- ================= FOCUS ================= -->
    <section id="focus" class="section shell">
      <p class="eyebrow" data-reveal>focus</p>
      <h2 class="section-title" data-reveal>What I do</h2>
      <div class="focus-grid">
        {focus.map((f, i) => (
          <article class="focus-card" data-reveal style={`--reveal-delay: ${i * 70}ms`}>
            <span class="focus-k">{f.k}</span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ================= EXPERIENCE ================= -->
    <section id="experience" class="section shell">
      <p class="eyebrow" data-reveal>signal</p>
      <div class="exp">
        <div class="exp-lead">
          <h2 class="section-title" data-reveal>
            I turn models into<br /><span class="accent-text">fast, dependable endpoints.</span>
          </h2>
          <div class="stats" data-reveal style="--reveal-delay: 140ms">
            {stats.map((s) => (
              <div class="stat">
                <span
                  class="stat-num"
                  data-count={s.value}
                  data-decimals={s.decimals}
                  data-prefix={s.prefix}
                  data-suffix={s.suffix}
                >{s.prefix}0{s.suffix}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="exp-body" data-reveal style="--reveal-delay: 90ms">
          <p>
            I'm an AI Systems Engineer and MS Computer Science student at NYU, focused on the part of
            machine learning that decides whether it's actually useful: <strong>how it's served.</strong>{' '}
            My work sits where software engineering, systems, and ML meet — making inference fast, cheap,
            and reliable at scale.
          </p>
          <ul class="exp-list">
            {highlights.map((h) => <li>{h}</li>)}
          </ul>
          <div class="creds">
            {creds.map((c) => <span class="cred">{c}</span>)}
          </div>
        </div>
      </div>
    </section>

    <!-- ================= WORK ================= -->
    <section id="work" class="section shell">
      <p class="eyebrow" data-reveal>work</p>
      <h2 class="section-title" data-reveal>Selected projects</h2>
      <div class="work-grid">
        {projects.map((p, i) => (
          <a class="work-card" data-tilt href={p.url} target="_blank" rel="noopener" data-reveal style={`--reveal-delay: ${i * 55}ms`}>
            <span class="work-glare" aria-hidden="true"></span>
            <div class="work-inner">
              <div class="work-top">
                <span class="work-tag">{p.tag}</span>
                <span class="work-open" aria-hidden="true">→</span>
              </div>
              <h3 class="work-name">{p.name}</h3>
              <p class="work-desc">{p.desc}</p>
              <div class="work-meta">
                <span class="work-lang"><span class="lang-dot"></span>{p.lang}</span>
                {p.star > 0 && <span class="work-star">★ {p.star}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
      <a class="all-repos" href="https://github.com/Nightshade14?tab=repositories" target="_blank" rel="noopener" data-reveal>
        All repositories on GitHub <span aria-hidden="true">↗</span>
      </a>
    </section>

    <!-- ================= RESEARCH ================= -->
    <section id="research" class="section shell">
      <p class="eyebrow" data-reveal>research</p>
      <div class="paper" data-reveal>
        <span class="paper-badge">Published · peer-reviewed</span>
        <h3 class="paper-title">
          Benchmarking Fine-Tuned Transformers, LLMs and LSTM Networks for Automated Essay Scoring
        </h3>
        <p class="paper-desc">
          A comparative study of how transformer fine-tuning, large language models, and recurrent
          baselines trade off accuracy against the cost of scoring at scale — with the fine-tuned
          approach exceeding prior benchmarks by 5.7%.
        </p>
        <div class="paper-links">
          <a class="paper-cta" href={PAPER_URL} target="_blank" rel="noopener">
            Read on ResearchGate <span aria-hidden="true">↗</span>
          </a>
          <a class="paper-pdf" href={PAPER_PDF} target="_blank" rel="noopener">PDF</a>
        </div>
      </div>
    </section>

    <!-- ================= CONTACT / FOOTER ================= -->
    <footer id="contact" class="footer">
      <div class="shell">
        <p class="eyebrow" data-reveal>connect</p>
        <h2 class="footer-title" data-reveal>Let's make something respond faster.</h2>
        <div class="link-grid" data-reveal style="--reveal-delay: 90ms">
          {links.map((l) => (
            <a class="link-row" href={l.url} target="_blank" rel="noopener">
              <span class="link-label">{l.label}</span>
              <span class="link-handle">{l.handle}</span>
            </a>
          ))}
        </div>
        <div class="footer-foot">
          <span class="foot-brand"><span class="brand-dot"></span>Satyam Chatrola</span>
          <span class="foot-note">Built with Astro · hosted on GitHub Pages · © 2026</span>
        </div>
      </div>
    </footer>
  </main>

  <script define:vars={{ RESPONSES }}>
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // Pointer-driven effects only make sense with a precise pointer (skip touch).
    const finePointer = window.matchMedia('(pointer: fine)').matches;
    const interactive = finePointer && !prefersReduced;

    /* ---- Signature: stream the hero "response" token by token, re-runnable via "resample". ---- */
    const el = document.getElementById('decode');
    const cursor = document.getElementById('cursor');
    const tokEl = document.getElementById('tokcount');
    const rateEl = document.getElementById('tokrate');
    const fill = document.getElementById('telfill');
    const statusEl = document.getElementById('telstatus');
    const regen = document.getElementById('regen');
    let decodeToken = 0;
    let respIndex = 0;

    function setDone(text, count, rate) {
      el.textContent = text;
      tokEl.textContent = String(count);
      rateEl.textContent = String(rate);
      fill.style.width = '100%';
      statusEl.textContent = 'done';
      statusEl.classList.add('is-done');
      cursor.classList.add('is-idle');
    }

    function runDecode(text, lead) {
      const myToken = ++decodeToken; // supersede any in-flight decode
      el.setAttribute('aria-label', text);
      const tokens = text.match(/\s*\S+/g) || [text];
      if (prefersReduced || !el) { setDone(text, tokens.length, 187); return; }
      el.textContent = '';
      tokEl.textContent = '0';
      fill.style.width = '0%';
      statusEl.textContent = 'streaming';
      statusEl.classList.remove('is-done');
      cursor.classList.remove('is-idle');
      let i = 0, start = 0;
      const per = 28;
      function step() {
        if (myToken !== decodeToken) return;
        if (i === 0) start = performance.now();
        if (i >= tokens.length) {
          const secs = (performance.now() - start) / 1000;
          setDone(text, tokens.length, Math.round(tokens.length / Math.max(secs, 0.001)));
          return;
        }
        el.textContent += tokens[i];
        i += 1;
        tokEl.textContent = String(i);
        fill.style.width = (i / tokens.length) * 100 + '%';
        setTimeout(step, per);
      }
      setTimeout(step, lead);
    }

    runDecode(RESPONSES[0], 520);
    if (regen) {
      regen.addEventListener('click', () => {
        respIndex = (respIndex + 1) % RESPONSES.length;
        regen.classList.add('is-spinning');
        setTimeout(() => regen.classList.remove('is-spinning'), 520);
        runDecode(RESPONSES[respIndex], 120);
      });
    }

    /* ---- Cursor spotlight: a soft cyan light that trails the pointer. ---- */
    const spotlight = document.querySelector('.spotlight');
    if (spotlight && interactive) {
      let sx = window.innerWidth / 2, sy = window.innerHeight * 0.28;
      let tx = sx, ty = sy, raf = 0;
      const loop = () => {
        sx += (tx - sx) * 0.12;
        sy += (ty - sy) * 0.12;
        spotlight.style.transform = `translate(${sx}px, ${sy}px) translate(-50%, -50%)`;
        raf = (Math.abs(tx - sx) > 0.4 || Math.abs(ty - sy) > 0.4) ? requestAnimationFrame(loop) : 0;
      };
      window.addEventListener('pointermove', (e) => {
        tx = e.clientX; ty = e.clientY;
        if (!raf) raf = requestAnimationFrame(loop);
      }, { passive: true });
      spotlight.classList.add('on');
    }

    /* ---- Magnetic buttons: gently pull toward the pointer, spring back on leave. ---- */
    if (interactive) {
      document.querySelectorAll('[data-magnetic]').forEach((node) => {
        node.style.willChange = 'transform';
        node.addEventListener('pointermove', (e) => {
          const r = node.getBoundingClientRect();
          const mx = e.clientX - (r.left + r.width / 2);
          const my = e.clientY - (r.top + r.height / 2);
          node.style.transform = `translate(${mx * 0.3}px, ${my * 0.4}px)`;
        });
        node.addEventListener('pointerleave', () => { node.style.transform = ''; });
      });

      /* ---- Project cards: 3D tilt toward the pointer with a glare that follows it. ---- */
      document.querySelectorAll('[data-tilt]').forEach((card) => {
        const glare = card.querySelector('.work-glare');
        const MAX = 6;
        card.addEventListener('pointerenter', () => { card.style.transition = 'transform 0.05s linear'; });
        card.addEventListener('pointermove', (e) => {
          const r = card.getBoundingClientRect();
          const px = (e.clientX - r.left) / r.width;
          const py = (e.clientY - r.top) / r.height;
          card.style.transform =
            `perspective(820px) rotateX(${(0.5 - py) * MAX * 2}deg) rotateY(${(px - 0.5) * MAX * 2}deg) translateY(-4px)`;
          if (glare) {
            glare.style.opacity = '1';
            glare.style.background =
              `radial-gradient(260px circle at ${px * 100}% ${py * 100}%, rgba(34,211,238,0.16), transparent 62%)`;
          }
        });
        card.addEventListener('pointerleave', () => {
          card.style.transition = ''; // restore the springy CSS transition for the return
          card.style.transform = '';
          if (glare) glare.style.opacity = '0';
        });
      });
    }

    /* ---- Count-up stats when they scroll into view. ---- */
    const counters = document.querySelectorAll('[data-count]');
    const animateCount = (node) => {
      const target = parseFloat(node.dataset.count);
      const decimals = parseInt(node.dataset.decimals || '0', 10);
      const prefix = node.dataset.prefix || '';
      const suffix = node.dataset.suffix || '';
      const render = (v) => { node.textContent = prefix + v.toFixed(decimals) + suffix; };
      if (prefersReduced) { render(target); return; }
      const dur = 1100, start = performance.now();
      const tick = (now) => {
        const t = Math.min((now - start) / dur, 1);
        render(target * (1 - Math.pow(1 - t, 3)));
        if (t < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };
    if (counters.length && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => { if (en.isIntersecting) { animateCount(en.target); io.unobserve(en.target); } });
      }, { threshold: 0.6 });
      counters.forEach((c) => io.observe(c));
    } else {
      counters.forEach(animateCount);
    }
  </script>

  <style>
    /* ===================== NAV ===================== */
    .nav {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(12px);
      background: color-mix(in oklab, var(--bg) 72%, transparent);
      border-bottom: 1px solid var(--line);
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 62px;
    }
    .brand {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      letter-spacing: 0.02em;
      color: var(--text);
      display: inline-flex;
      align-items: center;
      gap: 0.55em;
    }
    .brand-2 { color: var(--text-faint); }
    .brand-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 10px var(--accent-glow);
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: clamp(1rem, 2vw, 2rem);
      font-family: var(--font-mono);
      font-size: var(--step--1);
    }
    .nav-links > a:not(.btn) {
      color: var(--text-dim);
      transition: color 0.2s;
      position: relative;
    }
    .nav-links > a:not(.btn):hover { color: var(--text); }
    .nav-links > a:not(.btn)::after {
      content: "";
      position: absolute;
      left: 0; bottom: -6px;
      width: 100%; height: 1px;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .nav-links > a:not(.btn):hover::after { transform: scaleX(1); }
    @media (max-width: 620px) {
      .nav-links > a:not(.btn) { display: none; }
    }

    /* ===================== BUTTONS ===================== */
    .btn {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      letter-spacing: 0.01em;
      padding: 0.68em 1.15em;
      border: 1px solid var(--line-2);
      border-radius: 999px;
      color: var(--text);
      transition: border-color 0.2s, background 0.2s, color 0.2s, transform 0.2s;
      white-space: nowrap;
    }
    .btn:hover { border-color: var(--text); transform: translateY(-1px); }
    .btn-sm { padding: 0.5em 0.95em; }
    .btn-primary {
      background: var(--accent);
      border-color: var(--accent);
      color: #05171c;
      font-weight: 500;
    }
    .btn-primary:hover {
      background: var(--accent-hi);
      border-color: var(--accent-hi);
      box-shadow: 0 0 30px var(--accent-glow);
    }

    /* ===================== HERO ===================== */
    .hero {
      padding-top: clamp(3.5rem, 8vh, 7rem);
      padding-bottom: clamp(3.5rem, 8vh, 7rem);
      display: grid;
      grid-template-columns: 1.02fr 0.98fr;
      align-items: center;
      gap: clamp(1.5rem, 4vw, 3.5rem);
    }
    .hero-visual { position: relative; min-width: 0; }
    @media (max-width: 900px) {
      .hero {
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      .hero-visual { order: -1; } /* show the GPU above the copy on narrow screens */
    }
    .prompt {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--text-faint);
      letter-spacing: 0.05em;
      margin-bottom: 1.4rem;
    }
    .prompt-caret { color: var(--accent); margin-right: 0.4em; }
    .hero-name {
      font-size: var(--step-4);
      font-weight: 700;
      letter-spacing: -0.035em;
      line-height: 0.92;
      margin-bottom: 1.6rem;
    }
    .hero-response {
      font-family: var(--font-mono);
      font-size: clamp(1rem, 0.9rem + 0.9vw, 1.4rem);
      line-height: 1.55;
      color: var(--text-dim);
      max-width: min(42ch, 100%);
      overflow-wrap: break-word;
      min-height: 6em; /* reserve space so streaming doesn't reflow the page */
      margin-bottom: 1.6rem;
    }
    .hero-response strong, .accent-text { color: var(--accent); font-weight: inherit; }
    .cursor {
      display: inline-block;
      width: 0.6ch;
      height: 1.05em;
      transform: translateY(0.18em);
      margin-left: 0.08em;
      background: var(--accent);
      animation: blink 1s steps(2, start) infinite;
    }
    .cursor.is-idle { animation-duration: 1.4s; opacity: 0.7; }
    @keyframes blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }
    @media (prefers-reduced-motion: reduce) { .cursor { animation: none; } }

    .telemetry {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--text-faint);
      margin-bottom: 2.4rem;
      flex-wrap: wrap;
    }
    .tel-sep { opacity: 0.5; }
    .tel-item span { color: var(--accent); }
    .tel-bar {
      width: 88px; height: 3px;
      background: var(--line-2);
      border-radius: 2px;
      overflow: hidden;
    }
    .tel-fill {
      display: block; height: 100%; width: 0%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent-glow);
      transition: width 0.12s linear;
    }
    .tel-status { color: var(--text-faint); }
    .tel-status.is-done { color: var(--accent); }
    .hero-cta { display: flex; gap: 0.8rem; flex-wrap: wrap; }

    /* ===================== SECTIONS ===================== */
    .section {
      padding-block: clamp(3.5rem, 9vh, 7rem);
      border-top: 1px solid var(--line);
    }
    .section-title {
      font-size: var(--step-2);
      margin-top: 0.8rem;
      margin-bottom: 2.6rem;
      max-width: 20ch;
    }
    .accent-text { font-weight: inherit; }

    /* ---- focus grid ---- */
    .focus-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      overflow: hidden;
    }
    .focus-card {
      background: var(--bg);
      padding: clamp(1.4rem, 3vw, 2.2rem);
      transition: background 0.3s;
    }
    .focus-card:hover { background: var(--bg-1); }
    .focus-k {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--accent);
      letter-spacing: 0.04em;
    }
    .focus-card h3 { font-size: var(--step-1); margin: 0.9rem 0 0.7rem; }
    .focus-card p { color: var(--text-dim); max-width: 46ch; }
    @media (max-width: 680px) {
      .focus-grid { grid-template-columns: 1fr; }
    }

    /* ---- experience ---- */
    .exp { display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(1.5rem, 5vw, 4rem); }
    .exp .section-title { margin-bottom: 0; }
    .exp-body p { color: var(--text-dim); margin-bottom: 1.6rem; }
    .exp-body strong { color: var(--text); font-weight: 500; }
    .exp-list { list-style: none; padding: 0; display: grid; gap: 1rem; }
    .exp-list li {
      position: relative;
      padding-left: 1.5rem;
      color: var(--text-dim);
      font-size: var(--step--1);
      line-height: 1.6;
    }
    .exp-list li::before {
      content: "→";
      position: absolute; left: 0;
      color: var(--accent);
      font-family: var(--font-mono);
    }
    .creds { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1.8rem; }
    .cred {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--text-dim);
      padding: 0.35em 0.8em;
      border: 1px solid var(--line-2);
      border-radius: 999px;
      transition: border-color 0.2s, color 0.2s;
    }
    .cred:hover { border-color: var(--accent-line); color: var(--text); }
    @media (max-width: 800px) { .exp { grid-template-columns: 1fr; } }

    /* ---- work grid ---- */
    .work-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
    .work-card {
      display: flex;
      flex-direction: column;
      background: var(--bg-1);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 1.4rem;
      min-height: 210px;
      transition: border-color 0.28s, transform 0.28s, background 0.28s;
    }
    .work-card:hover {
      border-color: var(--accent-line);
      transform: translateY(-3px);
      background: var(--bg-2);
    }
    .work-top { display: flex; justify-content: space-between; align-items: center; }
    .work-tag {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--accent);
      padding: 0.2em 0.6em;
      border: 1px solid var(--accent-line);
      border-radius: 999px;
      background: var(--accent-dim);
    }
    .work-open {
      font-family: var(--font-mono);
      color: var(--text-faint);
      transform: translateX(-4px);
      opacity: 0;
      transition: transform 0.28s, opacity 0.28s, color 0.28s;
    }
    .work-card:hover .work-open { opacity: 1; transform: translateX(0); color: var(--accent); }
    .work-name {
      font-family: var(--font-mono);
      font-size: var(--step-1);
      font-weight: 500;
      letter-spacing: -0.01em;
      margin: 1rem 0 0.6rem;
    }
    .work-desc { color: var(--text-dim); font-size: var(--step--1); line-height: 1.55; flex: 1; }
    .work-meta {
      display: flex; align-items: center; gap: 1rem;
      margin-top: 1.2rem;
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--text-faint);
    }
    .lang-dot {
      display: inline-block; width: 8px; height: 8px; border-radius: 50%;
      background: var(--accent); margin-right: 0.5em; vertical-align: middle;
      opacity: 0.7;
    }
    .work-star { color: var(--accent); }
    @media (max-width: 900px) { .work-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .work-grid { grid-template-columns: 1fr; } }

    .all-repos {
      display: inline-flex;
      margin-top: 2rem;
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--text-dim);
      border-bottom: 1px solid var(--line-2);
      padding-bottom: 3px;
      transition: color 0.2s, border-color 0.2s;
    }
    .all-repos:hover { color: var(--accent); border-color: var(--accent-line); }

    /* ---- research paper (single featured card, left accent rule) ---- */
    .paper {
      position: relative;
      border: 1px solid var(--line);
      border-left: 2px solid var(--accent-line);
      border-radius: var(--radius);
      padding: clamp(1.6rem, 4vw, 2.8rem);
      background:
        radial-gradient(120% 140% at 0% 0%, rgba(34,211,238,0.07), transparent 55%),
        var(--bg-1);
      transition: border-color 0.3s, transform 0.3s, background 0.3s;
    }
    .paper:hover {
      border-color: var(--accent-line);
      border-left-color: var(--accent);
      transform: translateY(-3px);
    }
    .paper-badge {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--accent);
      letter-spacing: 0.04em;
    }
    .paper-title {
      font-size: var(--step-2);
      line-height: 1.12;
      max-width: 24ch;
      margin: 1rem 0 1rem;
    }
    .paper-desc { color: var(--text-dim); max-width: 62ch; margin-bottom: 1.6rem; }
    .paper-links { display: flex; align-items: center; gap: 1.1rem; flex-wrap: wrap; }
    .paper-cta {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--accent);
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s;
    }
    .paper-cta:hover { border-color: var(--accent-line); }
    .paper-pdf {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--text-dim);
      border: 1px solid var(--line-2);
      border-radius: 6px;
      padding: 0.25em 0.75em;
      transition: border-color 0.2s, color 0.2s;
    }
    .paper-pdf:hover { color: var(--text); border-color: var(--text); }

    /* ===================== FOOTER ===================== */
    .footer {
      border-top: 1px solid var(--line);
      padding-block: clamp(3.5rem, 9vh, 7rem) 2.5rem;
      background:
        radial-gradient(90% 120% at 100% 100%, rgba(34,211,238,0.06), transparent 60%),
        var(--bg);
    }
    .footer-title {
      font-size: var(--step-2);
      margin: 0.8rem 0 2.6rem;
      max-width: 16ch;
    }
    .link-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      border-top: 1px solid var(--line);
    }
    .link-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 1.2rem 0.2rem;
      border-bottom: 1px solid var(--line);
      transition: padding-left 0.28s, color 0.2s;
    }
    .link-row:nth-child(odd) { border-right: 1px solid var(--line); padding-right: 1.4rem; }
    .link-row:nth-child(even) { padding-left: 1.4rem; }
    .link-row:hover { padding-left: 1.2rem; }
    .link-row:nth-child(even):hover { padding-left: 2.6rem; }
    .link-label { font-family: var(--font-display); font-size: var(--step-1); }
    .link-handle {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--text-faint);
      transition: color 0.2s;
    }
    .link-row:hover .link-handle { color: var(--accent); }
    @media (max-width: 620px) {
      .link-grid { grid-template-columns: 1fr; }
      .link-row:nth-child(odd) { border-right: none; padding-right: 0.2rem; }
      .link-row:nth-child(even) { padding-left: 0.2rem; }
      .link-row:nth-child(even):hover { padding-left: 1.2rem; }
    }
    .footer-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 2.5rem;
      flex-wrap: wrap;
      gap: 1rem;
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--text-faint);
    }
    .foot-brand { display: inline-flex; align-items: center; gap: 0.55em; color: var(--text-dim); }

    /* ===================== INTERACTIVE LAYER ===================== */
    /* cursor spotlight — soft cyan light trailing the pointer */
    .spotlight {
      position: fixed;
      top: 0; left: 0;
      width: 620px; height: 620px;
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
      opacity: 0;
      background: radial-gradient(circle, rgba(34, 211, 238, 0.09), transparent 62%);
      filter: blur(6px);
      transition: opacity 0.6s ease;
      will-change: transform;
    }
    .spotlight.on { opacity: 1; }
    @media (prefers-reduced-motion: reduce) { .spotlight { display: none; } }
    main { position: relative; z-index: 1; }

    /* brand dot "boop" on hover */
    .brand:hover .brand-dot,
    .foot-brand:hover .brand-dot {
      animation: boop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @keyframes boop {
      0% { transform: scale(1); }
      45% { transform: scale(1.9); box-shadow: 0 0 18px var(--accent); }
      100% { transform: scale(1); }
    }
    @media (prefers-reduced-motion: reduce) {
      .brand:hover .brand-dot, .foot-brand:hover .brand-dot { animation: none; }
    }

    /* hero meta row + resample control */
    .hero-meta {
      display: flex;
      align-items: center;
      gap: 0.9rem 1.4rem;
      flex-wrap: wrap;
      margin-bottom: 2.4rem;
    }
    .telemetry { margin-bottom: 0; }
    .regen {
      font-family: var(--font-mono);
      font-size: var(--step--1);
      color: var(--text-faint);
      background: transparent;
      border: 1px solid var(--line-2);
      border-radius: 999px;
      padding: 0.34em 0.85em;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 0.45em;
      transition: color 0.2s, border-color 0.2s, background 0.2s, transform 0.2s;
    }
    .regen:hover {
      color: var(--accent);
      border-color: var(--accent-line);
      background: var(--accent-dim);
      transform: translateY(-1px);
    }
    .regen:active { transform: translateY(0) scale(0.97); }
    .regen-ico { display: inline-block; transition: transform 0.3s; }
    .regen:hover .regen-ico { transform: rotate(-90deg); }
    .regen.is-spinning .regen-ico { animation: spin 0.52s cubic-bezier(0.5, 0, 0.2, 1); }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* count-up stats */
    .stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.6rem 2rem;
      margin-top: 2.6rem;
      max-width: 380px;
    }
    .stat { display: flex; flex-direction: column; gap: 0.35rem; }
    .stat-num {
      font-family: var(--font-display);
      font-size: clamp(2rem, 1.3rem + 2.6vw, 3.1rem);
      font-weight: 600;
      letter-spacing: -0.03em;
      line-height: 1;
      color: var(--accent);
      font-variant-numeric: tabular-nums;
    }
    .stat-label { font-family: var(--font-mono); font-size: var(--step--1); color: var(--text-faint); }
    @media (max-width: 800px) { .stats { margin-top: 2rem; max-width: none; } }

    /* project card tilt + glare */
    .work-card {
      position: relative;
      overflow: hidden;
      transform-style: preserve-3d;
      will-change: transform;
    }
    .work-inner { position: relative; z-index: 1; display: flex; flex-direction: column; flex: 1; }
    .work-glare {
      position: absolute;
      inset: 0;
      border-radius: inherit;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
      z-index: 2;
    }
  </style>
</Base>
